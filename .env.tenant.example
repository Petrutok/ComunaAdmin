# =============================================================================
# CONFIGURAREA UNEI COMUNE NOI (multi-tenancy)
# =============================================================================
# Fiecare comuna = propriul proiect Firebase + propriul proiect Vercel +
# propriul domeniu, toate construite din acest cod. Copiaza acest fisier,
# completeaza valorile si seteaza-le in proiectul Vercel al comunei.
# Ghid complet: docs/TENANT_ONBOARDING.md

# --- Identitatea comunei (apare in aplicatie, PDF-uri, emailuri) ------------
NEXT_PUBLIC_TENANT_COMUNA="Comuna Exemplu"
NEXT_PUBLIC_TENANT_PRIMARIE="Primăria Exemplu"
NEXT_PUBLIC_TENANT_ANTET="PRIMĂRIA COMUNEI EXEMPLU"
NEXT_PUBLIC_TENANT_JUDET="Județul Exemplu"
NEXT_PUBLIC_TENANT_TELEFON="0234/000.000"
NEXT_PUBLIC_TENANT_EMAIL="contact@primaria-exemplu.ro"

# Stema/logo-ul comunei: URL absolut (ex. imagine urcata in Firebase Storage
# cu acces public) sau lasa gol pentru logo-ul implicit din repo
NEXT_PUBLIC_TENANT_LOGO_URL=""

# Domeniul de productie al acestei comune
NEXT_PUBLIC_API_URL="https://primaria-exemplu.ro"

# Emailuri cu acces la ecranul de login admin (fallback UI; autorizarea
# reala e colectia `users` din Firestore)
NEXT_PUBLIC_FALLBACK_ADMIN_EMAILS="primar@primaria-exemplu.ro"

# --- Firebase (proiectul NOU, dedicat acestei comune) ------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Service account (Firebase Console -> Project settings -> Service accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Push notifications (chei VAPID noi: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL="mailto:contact@primaria-exemplu.ro"

# --- Email -------------------------------------------------------------------
# IMAP (registratura automata - casuta oficiala a primariei)
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_TLS=true

# Resend (notificari catre cetateni) - domeniu verificat in resend.com
RESEND_API_KEY=
RESEND_FROM="Primăria Exemplu <noreply@primaria-exemplu.ro>"

# --- Cron --------------------------------------------------------------------
CRON_SECRET=
